<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The B-Side — Issue No. 01</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>

/* ── Reset ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── Tokens ── */
:root {
  --cream:        #F4EFE4;
  --cream-mid:    #EDE6D6;
  --cream-dark:   #E3D9C4;
  --ink:          #1A1814;
  --ink-mid:      #3D3829;
  --ink-light:    #7A7060;
  --ink-faint:    #A89F90;
  --amber:        #B5721A;
  --amber-warm:   #C98428;
  --rule:         #C9BAA0;
  --serif:        'Playfair Display', Georgia, serif;
  --sans:         'Inter', system-ui, sans-serif;
}

/* ── Base ── */
html { scroll-behavior: smooth; }
body {
  background: var(--cream-dark);
  font-family: var(--sans);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
  line-height: 1;
}
a { color: var(--amber); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ── Page shell ── */
.page {
  max-width: 700px;
  margin: 0 auto;
  background: var(--cream);
}

/* ════════════════════════════
   HEADER
════════════════════════════ */
.header {
  padding: 2.5rem 3rem 0;
  border-bottom: 1.5px solid var(--ink);
}
.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 1.8rem;
}
.header-meta {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.meta-issue {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-light);
}
.meta-date {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-faint);
}
.header-refresh {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.4rem;
}
.refresh-ts {
  font-family: var(--sans);
  font-size: 10px;
  color: var(--ink-faint);
  letter-spacing: 0.06em;
}
.refresh-btn {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--amber);
  background: none;
  border: 1px solid var(--amber);
  padding: 0.35rem 0.8rem;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
}
.refresh-btn:hover {
  background: var(--amber);
  color: var(--cream);
}

/* Masthead */
.masthead-wrap {
  text-align: center;
  padding-bottom: 1.4rem;
}
.greeting {
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-light);
  margin-bottom: 0.8rem;
  display: block;
}
.masthead {
  font-family: var(--serif);
  font-size: 80px;
  font-weight: 400;
  letter-spacing: -0.035em;
  line-height: 0.9;
  color: var(--ink);
  margin-bottom: 1.2rem;
}
.tagline-rule {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.tagline-line {
  flex: 1;
  height: 0.5px;
  background: var(--rule);
}
.tagline-text {
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 500;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-light);
  white-space: nowrap;
}

/* ════════════════════════════
   VIBE STRIP
════════════════════════════ */
.vibe {
  width: 100%;
  height: 240px;
  background: #231D14;
  display: flex;
  align-items: flex-end;
  padding: 1.5rem 3rem;
  position: relative;
  overflow: hidden;
}
.vibe-caption {
  font-family: var(--serif);
  font-style: italic;
  font-size: 14px;
  color: rgba(244,239,228,0.55);
  letter-spacing: 0.04em;
  position: relative;
  z-index: 1;
}

/* ════════════════════════════
   SECTION COMMONS
════════════════════════════ */
.body { padding: 0 3rem; }

.section {
  padding: 2.4rem 0;
  border-bottom: 0.5px solid var(--rule);
}
.section:last-of-type { border-bottom: none; }

.eyebrow {
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--amber);
  display: block;
  margin-bottom: 0.6rem;
}
.section-hed {
  font-family: var(--serif);
  font-size: 28px;
  font-weight: 400;
  line-height: 1.18;
  color: var(--ink);
  margin-bottom: 1rem;
}
.section-hed em { font-style: italic; }

.body-text {
  font-family: var(--sans);
  font-size: 15px;
  font-weight: 300;
  line-height: 1.8;
  color: var(--ink-mid);
}
.body-text + .body-text { margin-top: 0.85rem; }

.pull-quote {
  border-left: 2.5px solid var(--amber);
  margin: 1.4rem 0 0;
  padding: 0.25rem 0 0.25rem 1rem;
  font-family: var(--serif);
  font-style: italic;
  font-size: 16px;
  line-height: 1.5;
  color: var(--ink-light);
}

/* ── Buzz meter ── */
.buzz-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin: 1.1rem 0 0.8rem;
}
.buzz-label {
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-faint);
  white-space: nowrap;
}
.buzz-bar-track {
  flex: 1;
  height: 3px;
  background: var(--cream-dark);
  border-radius: 2px;
  max-width: 120px;
}
.buzz-bar-fill {
  height: 100%;
  background: var(--amber);
  border-radius: 2px;
}
.buzz-score {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 600;
  color: var(--amber);
  letter-spacing: 0.06em;
}

/* ── Sources ── */
.sources {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.8rem;
}
.source-link {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.08em;
  color: var(--ink-light);
  border-bottom: 1px solid var(--rule);
  padding-bottom: 1px;
  transition: color 0.15s, border-color 0.15s;
}
.source-link:hover {
  color: var(--amber);
  border-color: var(--amber);
  text-decoration: none;
}
.source-sep {
  color: var(--rule);
  font-size: 10px;
  align-self: center;
}
.single-source-badge {
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--cream);
  background: var(--ink-light);
  padding: 0.2rem 0.5rem;
  align-self: center;
}

/* ── Why it matters ── */
.why-matters {
  margin-top: 1rem;
  padding: 0.9rem 1.1rem;
  background: var(--cream-mid);
  border-left: 2.5px solid var(--amber);
}
.why-label {
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--amber);
  display: block;
  margin-bottom: 0.4rem;
}
.why-text {
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 400;
  line-height: 1.65;
  color: var(--ink-mid);
}

/* ════════════════════════════
   THE BUZZ — 2×2 GRID
════════════════════════════ */
.buzz-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5px;
  margin-top: 1.2rem;
  background: var(--rule);
}
.buzz-card {
  background: var(--cream);
  padding: 1.4rem 1.3rem;
}
.buzz-card-tag {
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--amber);
  display: block;
  margin-bottom: 0.5rem;
}
.buzz-card-hed {
  font-family: var(--serif);
  font-size: 17px;
  font-weight: 400;
  line-height: 1.25;
  color: var(--ink);
  margin-bottom: 0.7rem;
}
.buzz-card-body {
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 300;
  line-height: 1.7;
  color: var(--ink-mid);
}

/* ── Mood image between sections ── */
.mood-img {
  width: calc(100% + 6rem);
  margin-left: -3rem;
  height: 170px;
  background: #2A2217;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 0;
}
.mood-img-label {
  font-family: var(--sans);
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #4A3F2E;
}

/* ════════════════════════════
   WHAT DROPPED
════════════════════════════ */
.dropped-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1.5rem;
  margin-top: 1.2rem;
}
.dropped-col-label {
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink-faint);
  display: block;
  margin-bottom: 1rem;
  padding-bottom: 0.6rem;
  border-bottom: 0.5px solid var(--rule);
}
.dropped-item {
  margin-bottom: 1.2rem;
}
.dropped-item:last-child { margin-bottom: 0; }
.dropped-title {
  font-family: var(--serif);
  font-size: 14px;
  font-weight: 400;
  line-height: 1.3;
  color: var(--ink);
  margin-bottom: 0.2rem;
}
.dropped-creator {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  color: var(--amber);
  letter-spacing: 0.06em;
  display: block;
  margin-bottom: 0.4rem;
}
.dropped-take {
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 300;
  line-height: 1.65;
  color: var(--ink-mid);
}
.dropped-where {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 400;
  color: var(--ink-faint);
  margin-top: 0.3rem;
  font-style: italic;
}

/* ════════════════════════════
   TRENDING
════════════════════════════ */
.trending-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 1.2rem;
}
.trending-item {
  padding: 1.3rem 0;
  border-bottom: 0.5px solid var(--rule);
}
.trending-item:last-child { border-bottom: none; }
.trending-num {
  font-family: var(--serif);
  font-style: italic;
  font-size: 11px;
  color: var(--amber);
  display: block;
  margin-bottom: 0.4rem;
}
.trending-hed {
  font-family: var(--serif);
  font-size: 17px;
  font-weight: 400;
  line-height: 1.25;
  color: var(--ink);
  margin-bottom: 0.6rem;
}
.trending-body {
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 300;
  line-height: 1.7;
  color: var(--ink-mid);
}
.trending-body + .trending-body { margin-top: 0.5rem; }
.trending-source {
  display: inline-block;
  margin-top: 0.6rem;
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  color: var(--ink-faint);
  letter-spacing: 0.06em;
}

/* ════════════════════════════
   WEEKEND PICKS
════════════════════════════ */
.picks-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1.5px;
  margin-top: 1.2rem;
  background: var(--rule);
}
.pick-card {
  background: var(--cream);
  padding: 1.4rem 1.2rem;
}
.pick-type {
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink-faint);
  display: block;
  margin-bottom: 0.5rem;
}
.pick-title {
  font-family: var(--serif);
  font-size: 15px;
  font-weight: 400;
  line-height: 1.25;
  color: var(--ink);
  margin-bottom: 0.6rem;
}
.pick-body {
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 300;
  line-height: 1.7;
  color: var(--ink-mid);
  margin-bottom: 0.6rem;
}
.pick-where {
  font-family: var(--sans);
  font-size: 10px;
  color: var(--amber);
  font-weight: 500;
  letter-spacing: 0.04em;
}

/* ════════════════════════════
   CONVERSATION STARTER
════════════════════════════ */
.convo-inner {
  background: var(--ink);
  padding: 2rem 2.2rem;
  margin-top: 1.2rem;
}
.convo-label {
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--amber);
  display: block;
  margin-bottom: 0.8rem;
}
.convo-topic {
  font-family: var(--serif);
  font-style: italic;
  font-size: 18px;
  color: var(--cream);
  line-height: 1.3;
  margin-bottom: 0.9rem;
}
.convo-body {
  font-family: var(--sans);
  font-size: 14px;
  font-weight: 300;
  line-height: 1.75;
  color: rgba(244,239,228,0.75);
}

/* ════════════════════════════
   QUICK HITS
════════════════════════════ */
.hits-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 1.2rem;
}
.hit-item {
  display: grid;
  grid-template-columns: 24px 1fr auto;
  gap: 0.8rem;
  align-items: baseline;
  padding: 0.9rem 0;
  border-bottom: 0.5px solid var(--rule);
}
.hit-item:last-child { border-bottom: none; }
.hit-num {
  font-family: var(--serif);
  font-style: italic;
  font-size: 13px;
  color: var(--amber);
}
.hit-text {
  font-family: var(--sans);
  font-size: 14px;
  font-weight: 300;
  line-height: 1.65;
  color: var(--ink-mid);
}
.hit-src {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  color: var(--ink-faint);
  letter-spacing: 0.06em;
  white-space: nowrap;
  border-bottom: 1px solid var(--rule);
  padding-bottom: 1px;
  transition: color 0.15s, border-color 0.15s;
}
.hit-src:hover {
  color: var(--amber);
  border-color: var(--amber);
  text-decoration: none;
}

/* ════════════════════════════
   SOURCE DIVERSITY
════════════════════════════ */
.sources-footer {
  background: var(--cream-mid);
  padding: 1.6rem 3rem;
  border-top: 0.5px solid var(--rule);
}
.sources-footer-label {
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-faint);
  display: block;
  margin-bottom: 0.9rem;
}
.sources-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.source-tag {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.08em;
  color: var(--ink-mid);
  padding: 0.3rem 0.7rem;
  border: 0.5px solid var(--rule);
  background: var(--cream);
}

/* ════════════════════════════
   CLOSER
════════════════════════════ */
.closer {
  background: var(--ink);
  padding: 2.5rem 3rem;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.closer-left {
  font-family: var(--serif);
  font-style: italic;
  font-size: 30px;
  color: var(--cream);
  line-height: 1.2;
}
.closer-right {
  text-align: right;
}
.closer-name {
  font-family: var(--serif);
  font-size: 14px;
  color: var(--rule);
  letter-spacing: 0.04em;
  display: block;
  margin-bottom: 0.25rem;
}
.closer-sub {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-light);
}

/* ════════════════════════════
   RESPONSIVE
════════════════════════════ */
@media (max-width: 600px) {
  .header, .body, .sources-footer, .closer { padding-left: 1.5rem; padding-right: 1.5rem; }
  .masthead { font-size: 52px; }
  .section-hed { font-size: 22px; }
  .buzz-grid, .picks-grid { grid-template-columns: 1fr; }
  .dropped-grid { grid-template-columns: 1fr; }
  .mood-img { width: calc(100% + 3rem); margin-left: -1.5rem; }
  .hit-item { grid-template-columns: 20px 1fr; }
  .hit-src { display: none; }
}

</style>
</head>
